# ===== Admin server (NestJS) =====
NODE_ENV=development
PORT=4000

# PostgreSQL (admin panel metadata bazasi)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/admin_panel?schema=public"

# Admin panel frontend manzillari (vergul bilan)
ADMIN_CLIENT_URL=http://localhost:5174

# ===== Statik super admin (hozircha) =====
SUPER_ADMIN_EMAIL=admin@example.uz
# Ishlab chiqarishda bcrypt hash ishlating (pastdagi buyruq bilan yarating):
#   node -e "console.log(require('bcrypt').hashSync('parol', 10))"
SUPER_ADMIN_PASSWORD_HASH=
# Dev qulayligi uchun (HASH bo'lmasa ishlatiladi) — PRODda ishlatmang:
SUPER_ADMIN_PASSWORD=admin123

# ===== JWT / Cookie =====
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
COOKIE_SECRET=change-me-cookie

# ===== Provisioning (VPS) =====
# provision.sh skript yo'li va ishchi papka
PROVISION_SCRIPT=/root/admin/provision.sh
PROVISION_CWD=/root/admin
# DNS uchun beriladigan public IP (bitta VPS bo'lsa doim shu IP)
SERVER_PUBLIC_IP=203.0.113.10
# Tenant serverlariga ajratiladigan port diapazoni
TENANT_PORT_MIN=5100
TENANT_PORT_MAX=5999
# study-center shabloni papkasi (seed uchun)
STUDY_CENTER_TEMPLATE_DIR=/root/templates/study-center
